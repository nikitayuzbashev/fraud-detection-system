# Application Configuration
APP_NAME=fraud-detection-api
APP_VERSION=1.0.0
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Model Configuration
MODEL_PATH=data/models/fraud_detector.joblib
THRESHOLD=0.5

# Data Configuration
DATA_PATH=data/raw/creditcard.csv

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=fraud-detection

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Model Training
RANDOM_STATE=42
TEST_SIZE=0.2
N_ESTIMATORS=100
MAX_DEPTH=6
LEARNING_RATE=0.1
